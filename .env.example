# AWS profile used by Makefile and scripts.
AWS_PROFILE=default

# Primary AWS region for Lambda, API Gateway, logs, and most regional services.
AWS_REGION=eu-central-1

# CloudFront viewer certificates must exist in us-east-1.
ACM_REGION=us-east-1

# Filled after Terraform creates or discovers the frontend bucket.
FRONTEND_BUCKET=

# Filled after Terraform creates or discovers the CloudFront distribution.
DISTRIBUTION_ID=

# Optional future custom domains.
FRONTEND_DOMAIN=mandelbrot.i-dmytro.org
API_DOMAIN=api-mandelbrot.i-dmytro.org
